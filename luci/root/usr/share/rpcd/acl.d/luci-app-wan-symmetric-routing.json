{
  "luci-app-wan-symmetric-routing": {
    "description": "Grant access to WAN Symmetric Routing",
    "read": {
      "uci": [
        "wan_vrf"
      ],
      "ubus": {
        "file": [
          "exec",
          "read",
          "stat"
        ]
      },
      "file": {
        "/etc/wan-vrf/diagnose.sh": ["exec"],
        "/etc/wan-vrf/apply.sh": ["exec"],
        "/etc/init.d/wan_vrf": ["exec"],
        "/bin/sh": ["exec"],
        "/tmp/wan-vrf.last_apply": ["read"]
      }
    },
    "write": {
      "uci": [
        "wan_vrf"
      ]
    }
  }
}
